{
  "name": "video",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate": "dotenv -e .env -- node --import tsx node_modules/knex/bin/cli.js migrate:latest --knexfile knexfile.ts",
    "db:rollback": "dotenv -e .env -- node --import tsx node_modules/knex/bin/cli.js migrate:rollback --knexfile knexfile.ts",
    "db:status": "dotenv -e .env -- node --import tsx node_modules/knex/bin/cli.js migrate:status --knexfile knexfile.ts",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:db": "docker compose up -d postgres",
    "docker:build": "docker compose build",
    "docker:logs": "docker compose logs -f"
  },
  "dependencies": {
    "@tiptap/extension-character-count": "^3.20.4",
    "@tiptap/extension-highlight": "^3.20.4",
    "@tiptap/extension-placeholder": "^3.20.4",
    "@tiptap/pm": "^3.20.4",
    "@tiptap/starter-kit": "^3.20.4",
    "@tiptap/vue-3": "^3.20.4",
    "bcryptjs": "^3.0.3",
    "jose": "^6.2.1",
    "knex": "^3.1.0",
    "nuxt": "^4.4.2",
    "pg": "^8.20.0",
    "shadcn-nuxt": "^2.4.3",
    "tiptap-markdown": "^0.9.0",
    "tslib": "^2.8.1",
    "tsx": "^4.21.0",
    "uuid": "^13.0.0",
    "vue": "^3.5.30",
    "vue-router": "^5.0.3",
    "vue-sonner": "^2.0.9",
    "vuedraggable": "^4.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@nuxt/test-utils": "^4.0.0",
    "@tailwindcss/vite": "^4.2.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/uuid": "^10.0.0",
    "@vue/test-utils": "^2.4.6",
    "@vueuse/core": "^14.2.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv-cli": "^11.0.0",
    "happy-dom": "^20.8.4",
    "lucide-vue-next": "^0.577.0",
    "reka-ui": "^2.9.2",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
